    },
    {
      "id": "2TWznTsXdokf_NXrjcyl0",
      "type": "text",
      "x": 2206.3468226114924,
      "y": 323.9975285847988,
      "width": 312.4398193359375,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b29",
      "roundness": null,
      "seed": 1459726204,
      "version": 317,
      "versionNonce": 1875574596,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777683185963,
      "link": null,
      "locked": false,
      "text": "POST /api/v1/<kind>/send\n\n<kind> : could be email, sms, etc.\n\nbody {\n    to: [ { userId: \"12345\" }  ],\n    from: { email: \"email\" },\n    subject: \"Hello world\",\n    content: [\n        {\n            type: \"text/plain\"\n            value: \"Hello world\"\n        }\n    ]\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST /api/v1/<kind>/send\n\n<kind> : could be email, sms, etc.\n\nbody {\n    to: [ { userId: \"12345\" }  ],\n    from: { email: \"email\" },\n    subject: \"Hello world\",\n    content: [\n        {\n            type: \"text/plain\"\n            value: \"Hello world\"\n        }\n    ]\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6WiFLkz-Pbgv4iCO_i2SW",
