    {
      "id": "9ltN0iaFlpNnNg9k0yoNO",
      "type": "text",
      "x": 3054.920337422721,
      "y": 212.15751190185597,
      "width": 897.0792846679688,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2D",
      "roundness": null,
      "seed": 1389686140,
      "version": 225,
      "versionNonce": 1178797892,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777683525355,
      "link": null,
      "locked": false,
      "text": "Design deep dive\n- Reliability\n- Additional component and considerations: template, notification configuration, rate limiting\n  retry mechanism, security, monitor queued notifications and event tracking",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design deep dive\n- Reliability\n- Additional component and considerations: template, notification configuration, rate limiting\n  retry mechanism, security, monitor queued notifications and event tracking",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7sPAMKf1yGGrDWu0Bcdx1",
      "type": "text",
      "x": 3071.370367431673,
      "y": 362.9762858072922,
      "width": 890.3394165039062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2E",
      "roundness": null,
      "seed": 1365482948,
      "version": 357,
      "versionNonce": 804776900,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777683658066,
      "link": null,
      "locked": false,
      "text": "How to prevent data loss?\nA important requirement in a notificatoin system is that it cannot lose data, notifications\ncan be delayed or re-ordered. To satisfy this requirement, the notificatoin system persists\nnotification data in a database and implements retry mechanism.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to prevent data loss?\nA important requirement in a notificatoin system is that it cannot lose data, notifications\ncan be delayed or re-ordered. To satisfy this requirement, the notificatoin system persists\nnotification data in a database and implements retry mechanism.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iFBnG2KjTIUrostMvjcvC",
      "type": "text",
      "x": 3080.120367431673,
      "y": 511.7262858072922,
      "width": 999.4395141601562,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2F",
      "roundness": null,
      "seed": 754947324,
      "version": 299,
      "versionNonce": 1773558268,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777684334443,
      "link": null,
      "locked": false,
      "text": "Will recipients receive a notification exactly once?\nAlthough notification is delivered exaclty once most of the time. To reduce the duplication occurrence\nwe introduce a dedupe mechanism and handle each failure case carefully.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Will recipients receive a notification exactly once?\nAlthough notification is delivered exaclty once most of the time. To reduce the duplication occurrence\nwe introduce a dedupe mechanism and handle each failure case carefully.",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
