    {
      "id": "eFb7677EGA5kVwKCCASK_",
      "type": "text",
      "x": 5478.493136358762,
      "y": 132.51605489881666,
      "width": 958.310302734375,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b21",
