      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1x",
      "roundness": null,
      "seed": 407580557,
      "version": 459,
      "versionNonce": 605068899,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765046257087,
      "link": null,
      "locked": false,
      "text": "Message id\n\nHow to generate message_id is an interesting topic as it carries the responsability\nof ensuring the order of messages\n- must be unique\n- should be sortable by time, meaning, new rows have higher values IDS than old ones",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Message id\n\nHow to generate message_id is an interesting topic as it carries the responsability\nof ensuring the order of messages\n- must be unique\n- should be sortable by time, meaning, new rows have higher values IDS than old ones",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gMUwwLtlK1XkeARuvl1Pr",
      "type": "text",
      "x": 4605.548638596857,
      "y": 711.2608058753792,
      "width": 793.5795288085938,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1y",
      "roundness": null,
      "seed": 1142184291,
      "version": 214,
      "versionNonce": 1503210829,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765046257087,
      "link": null,
      "locked": false,
      "text": "- Use auto increment\n- Use the glboal 64 bit sequence number generator like snowflake\n- local sequence number generator. Local means IDs are only unique within a group\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Use auto increment\n- Use the glboal 64 bit sequence number generator like snowflake\n- local sequence number generator. Local means IDs are only unique within a group\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
