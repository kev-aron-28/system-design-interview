    {
      "id": "nkdiMqJb-n0VWe_LaF-SO",
      "type": "text",
      "x": 2587.8799591064453,
      "y": 95.46608694029976,
      "width": 719.5594482421875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Z",
      "roundness": null,
      "seed": 2004490539,
      "version": 1722,
      "versionNonce": 2089401741,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765046257087,
      "link": null,
      "locked": false,
      "text": "Stateful service: The stateful service is the chat service. The service\nis stateful because each client maintains a persistent network connection\nto a chat service. In this service, a client normally does not swtich to \nanother chat server as logn as teh server is still available.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stateful service: The stateful service is the chat service. The service\nis stateful because each client maintains a persistent network connection\nto a chat service. In this service, a client normally does not swtich to \nanother chat server as logn as teh server is still available.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kISPMaE_h5QkwaV54UM_i",
      "type": "text",
      "x": 2595.039993286133,
      "y": 243.46608694029976,
      "width": 811.6395263671875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0b",
      "roundness": null,
      "seed": 621839781,
      "version": 2256,
      "versionNonce": 941911491,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765046257087,
      "link": null,
      "locked": false,
      "text": "Scalability\nOn a small scale,all services listed about could fit in one server. It is in theory\npossible to fit all users connections in one modern cloud server. The number of\nconcurrent connections that a server can handle will most likely be the limiting \nfactor. In our escenario at 1M connections users, assuming each takes 10K of\nmemory on the server, it only needs about 10 GB of memory to hold all connections\non one box",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scalability\nOn a small scale,all services listed about could fit in one server. It is in theory\npossible to fit all users connections in one modern cloud server. The number of\nconcurrent connections that a server can handle will most likely be the limiting \nfactor. In our escenario at 1M connections users, assuming each takes 10K of\nmemory on the server, it only needs about 10 GB of memory to hold all connections\non one box",
      "autoResize": true,
      "lineHeight": 1.25
    },
